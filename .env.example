# ─────────────────────────────────────────────────────────────────────
# AI Agents — Root environment file (example)
#
# Copy to `.env` and fill in values for local development, or use this
# as a reference for the variables consumed across all agents, the
# Slack bot, and the deployment manifests (Helm / Kubernetes).
#
#   cp .env.example .env
#
# For production on Kubernetes, prefer a Secret managed by External
# Secrets Operator, Sealed Secrets, or a vault provider — do NOT commit
# real values to this file.
# ─────────────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────────────
# Supported providers via `core/ai_agents_core/base.py::resolve_model`:
#   gemini (default) | claude | openai | ollama
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.0-flash
GEMINI_MODEL_VERSION=gemini-2.0-flash

# ── Google AI Studio (default path for Gemini) ───────────────────────
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# ── Vertex AI (alternative to AI Studio) ─────────────────────────────
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Anthropic / OpenAI / Ollama (via LiteLLM) ────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OLLAMA_API_BASE=http://localhost:11434

# ── Session storage ──────────────────────────────────────────────────
# DATABASE_URL takes precedence over the per-agent SQLite defaults.
# For multi-instance deployments you MUST use PostgreSQL — SQLite does
# not support concurrent writers.
#
# Default PostgreSQL credentials used in docker-compose.yml:
POSTGRES_USER=agents
POSTGRES_PASSWORD=agents_secret
POSTGRES_DB=agents

# Example (async driver recommended for the Slack bot):
#   postgresql+asyncpg://agents:agents_secret@postgres:5432/agents
# DATABASE_URL=

# ── Observability ────────────────────────────────────────────────────
ENABLE_METRICS_SERVER=true
HEALTH_PORT=8080
METRICS_PORT=9100
LOG_LEVEL=INFO

# ── Context caching (Gemini only) ────────────────────────────────────
CONTEXT_CACHE_MIN_TOKENS=2048
CONTEXT_CACHE_TTL_SECONDS=600
CONTEXT_CACHE_INTERVALS=10

# ── Target infrastructure (agent tools connect to these) ─────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
ALERTMANAGER_URL=http://localhost:9093

# ── Slack bot (only needed when running agents/slack-bot) ────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_BOT_PORT=3000
# Per-IP rate limit for the /slack/events endpoint (slowapi syntax).
SLACK_RATE_LIMIT=60/minute
# Trusted reverse-proxy hops for rate-limiter IP resolution. Set to the
# number of proxies between the public internet and this process (e.g.
# 1 behind ingress-nginx, 2 behind ingress-nginx + a cloud LB). Leave 0
# when exposed directly — otherwise callers can spoof X-Forwarded-For
# and bypass the limit.
SLACK_TRUSTED_PROXY_HOPS=0
# Comma-separated Slack user IDs mapped to RBAC roles. Unlisted users
# default to "viewer".
SLACK_ADMIN_USERS=
SLACK_OPERATOR_USERS=

# ── Google Chat bot (only needed when running agents/google-chat-bot) 
# Token audience — for HTTP endpoints, must match your Chat app's 
# URL character-for-character, including the trailing slash.
GOOGLE_CHAT_AUDIENCE=https://your-bot.example.com/
# Comma-separated emails mapped to RBAC roles.
GOOGLE_CHAT_ADMIN_EMAILS=
GOOGLE_CHAT_OPERATOR_EMAILS=
# Auth verification (recommended for production).
GOOGLE_CHAT_VERIFY_TOKEN=TRUE
# Comma-separated allowed service account emails.
# Standard: chat@system.gserviceaccount.com
# Add-ons: service-<PROJECT_NUMBER>@gcp-sa-gsuiteaddons.iam.gserviceaccount.com
GOOGLE_CHAT_IDENTITIES=chat@system.gserviceaccount.com

# ── Security / Auth (AEP-013, coming soon) ───────────────────────────
# JWT_SECRET=
# JWT_ISSUER=
# JWT_AUDIENCE=

# ── K8s tooling ──────────────────────────────────────────────────────
# Most tools auto-load kubeconfig; set only if you need an override.
# KUBECONFIG=~/.kube/config

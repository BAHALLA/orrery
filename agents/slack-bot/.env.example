# ─── slack-bot ───────────────────────────────────────────────────────
# Copy to `.env` in this same directory and fill in the values.
# Full setup guide: docs/slack-setup.md

# ─── Slack App credentials ───────────────────────────────────────────
# Create an app at https://api.slack.com/apps and install it to your workspace.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Only required for Socket Mode (no public HTTPS endpoint).
SLACK_APP_TOKEN=xapp-your-app-token

# HTTP mode listen port (ignored in Socket Mode).
# SLACK_BOT_PORT=3000

# Persistent session store. Sessions survive restarts.
# SLACK_DB_URL=sqlite+aiosqlite:///slack_devops.db

# ─── RBAC (comma-separated Slack user IDs) ───────────────────────────
# Users not listed default to "viewer".
SLACK_ADMIN_USERS=
SLACK_OPERATOR_USERS=

# ─── LLM provider (pick one block) ───────────────────────────────────

# Option A: Google AI Studio
# MODEL_PROVIDER=gemini
# MODEL_NAME=gemini-2.0-flash
# GOOGLE_API_KEY=your-api-key-here
# GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Option B: Google Vertex AI (uses Application Default Credentials)
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-pro
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Option C: Anthropic Claude
# MODEL_PROVIDER=anthropic
# MODEL_NAME=anthropic/claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...

# Option D: OpenAI
# MODEL_PROVIDER=openai
# MODEL_NAME=openai/gpt-4o
# OPENAI_API_KEY=sk-...

# ─── Infrastructure endpoints (forwarded to the orchestrated agents) ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
ALERTMANAGER_URL=http://localhost:9093
# KUBECONFIG_PATH=/home/you/.kube/config

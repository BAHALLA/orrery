# Elasticsearch REST endpoint
ELASTICSEARCH_URL=http://localhost:9200

# Authentication — pick one:
# ELASTICSEARCH_API_KEY=base64_encoded_api_key
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# TLS verification (set to false for self-signed certs in dev)
ELASTICSEARCH_VERIFY_CERTS=true

# HTTP timeout in seconds
ELASTICSEARCH_HTTP_TIMEOUT=15

# Optional: path to a CA bundle for verifying ES server cert
# ELASTICSEARCH_CA_CERTS=/path/to/ca.crt

# Optional: kubeconfig for ECK tools (empty = default ~/.kube/config, falls back to in-cluster)
# KUBECONFIG_PATH=
